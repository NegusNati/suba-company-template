{
  "name": "suba-company-template",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "better-auth": "^1.3.13",
      "dotenv": "^17.2.2",
      "zod": "^4.1.11",
      "typescript": "^5.8.2",
      "tsdown": "^0.15.5"
    }
  },
  "scripts": {
    "prepare": "husky",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "lint": "eslint . --max-warnings=0 --no-warn-ignored",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test:server": "turbo -F server test",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @suba-company-template/db db:push",
    "db:studio": "turbo -F @suba-company-template/db db:studio",
    "db:generate": "turbo -F @suba-company-template/db db:generate",
    "db:migrate": "turbo -F @suba-company-template/db db:migrate",
    "db:start": "turbo -F @suba-company-template/db db:start",
    "db:watch": "turbo -F @suba-company-template/db db:watch",
    "db:stop": "turbo -F @suba-company-template/db db:stop",
    "db:down": "turbo -F @suba-company-template/db db:down",
    "db:seed": "turbo -F @suba-company-template/db db:seed",
    "db:seed:append": "turbo -F @suba-company-template/db db:seed:append",
    "setup": "./scripts/setup.sh"
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.3",
    "@lexical/html": "^0.38.2",
    "@tanstack/react-router": "^1.133.22",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "isomorphic-dompurify": "^2.33.0",
    "motion": "^12.23.24",
    "motion-primitives": "^0.1.0",
    "ogl": "^1.0.11",
    "react-day-picker": "^9.11.1",
    "tech-stack-icons": "^3.3.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@ljharb/tsconfig": "^0.3.2",
    "@types/bun": "^1.2.6",
    "baseline-browser-mapping": "^2.9.13",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "eslint-plugin-unused-imports": "^4.1.3",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.3.3",
    "tsdown": "^0.15.5",
    "turbo": "^2.5.8",
    "typescript-eslint": "^8.18.1"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": [
      "bun format",
      "bun lint",
      "bun lint:fix",
      "bun format:check"
    ],
    "**/*.{json,md,yml,yaml,css,scss,html}": [
      "prettier --write"
    ]
  },
  "packageManager": "bun@1.3.0"
}
