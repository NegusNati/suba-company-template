{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["vite/client", "./src/types/tanstack-lazy-route"],
    "rootDirs": ["."],
    "paths": {
      "@/*": ["./src/*"],
      "@web/*": ["./src/*"],
      "@rich-text/*": ["./src/components/common/rich-text/*"]
    }
  },
  "include": ["src"]
}
