# =============================================================================
# COMPANY TEMPLATE - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# All apps and packages in this monorepo load environment variables from this
# root .env file.
#
# For production, ensure all placeholder values are updated with secure secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# These values are used by Docker Compose to create the PostgreSQL container
POSTGRES_DB=suba_app
POSTGRES_USER=suba
POSTGRES_PASSWORD=suba_password

# Connection string for the application
# For local development with Docker: postgresql://suba:suba_password@localhost:5432/suba_app
# For production: use your production database URL
DATABASE_URL=postgresql://suba:suba_password@localhost:5432/suba_app

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
SERVER_PORT=3000

# -----------------------------------------------------------------------------
# Better Auth Configuration
# -----------------------------------------------------------------------------
# Must be at least 32 characters - generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-secure-random-string-at-least-32-chars

# URL where the server is running (no trailing slash)
# Local: http://localhost:3000
# Production: https://api.yourdomain.com
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# Local: http://localhost:5173 (Vite default port)
# Production: https://yourdomain.com
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# -----------------------------------------------------------------------------
# OAuth Providers (Optional)
# -----------------------------------------------------------------------------
# Google OAuth - Get credentials from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Frontend Configuration (Vite)
# -----------------------------------------------------------------------------
# API server URL for frontend requests
VITE_SERVER_URL=http://localhost:3000

# Frontend URL (used for redirects, OAuth callbacks, etc.)
VITE_FRONTEND_URL=http://localhost:5173

# Site URL (used for OG images, sitemaps, canonical URLs)
# Production: https://yourdomain.com
VITE_SITE_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Site Branding (Server-side SSR)
# -----------------------------------------------------------------------------
# These are used for server-side rendered meta tags
SITE_NAME=Your Company
SITE_TITLE=Your Company | Software Engineering & Digital Innovation
SITE_DESCRIPTION=We craft intelligent software platforms and digital products.
TWITTER_HANDLE=@yourcompany

# -----------------------------------------------------------------------------
# Rate Limiting & Security (Optional - defaults shown)
# -----------------------------------------------------------------------------
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=600
# BODY_LIMIT_BYTES=10485760
# UPLOAD_MAX_BYTES=10485760
# GALLERY_UPLOAD_MAX_BYTES=83886080
